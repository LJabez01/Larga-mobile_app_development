{
  "expo": {
    "name": "Larga",
    "slug": "Largaaaaaaaaaaaaa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "larga",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.larga.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Allow Larga to access your photo library so you can upload documents.",
        "NSCameraUsageDescription": "Allow Larga to access your camera so you can take a photo of your ID.",
        "NSLocationWhenInUseUsageDescription": "Allow Larga to access your location so drivers can publish live trip updates."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2EBD85"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.larga.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Larga to access your photo library so you can upload documents.",
          "cameraPermission": "Allow Larga to access your camera so you can take a photo of your ID."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Larga to access your location so drivers can publish live trip updates."
        }
      ],
      [
        "@rnmapbox/maps",
        {}
      ],
      "expo-web-browser",
      "expo-notifications",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2e90e008-1839-46fd-a4a6-cc5788b8b931"
      }
    },
    "owner": "rodutalester"
  }
}
