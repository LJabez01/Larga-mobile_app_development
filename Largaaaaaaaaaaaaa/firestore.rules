rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDocPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function activeTripPath(uid) {
      return /databases/$(database)/documents/activeTrips/$(uid);
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(userDocPath(request.auth.uid))
        && get(userDocPath(request.auth.uid)).data.role == 'admin';
    }

    function isDriver() {
      return signedIn()
        && exists(userDocPath(request.auth.uid))
        && get(userDocPath(request.auth.uid)).data.role == 'driver';
    }

    function activeTripMatchesRequest(driverId, routeId) {
      return exists(activeTripPath(driverId))
        && get(activeTripPath(driverId)).data.driverId == driverId
        && get(activeTripPath(driverId)).data.routeId == routeId;
    }

    match /users/{uid} {
      allow create: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role == 'commuter'
        && request.resource.data.keys().hasOnly([
          'uid',
          'role',
          'email',
          'displayName',
          'phoneNumber',
          'createdAt',
          'updatedAt'
        ]);

      allow read: if isOwner(uid) || isAdmin();

      allow update: if (isOwner(uid) || isAdmin())
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.keys().hasOnly([
          'uid',
          'role',
          'email',
          'displayName',
          'phoneNumber',
          'createdAt',
          'updatedAt'
        ]);

      allow delete: if isAdmin();
    }

    match /routes/{routeId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /terminals/{terminalId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /activeTrips/{driverId} {
      allow read: if signedIn();

      allow create: if isDriver()
        && isOwner(driverId)
        && request.resource.data.driverId == request.auth.uid
        && request.resource.data.routeId is string
        && request.resource.data.originTerminalId is string
        && request.resource.data.destinationTerminalId is string
        && request.resource.data.originTerminalId != request.resource.data.destinationTerminalId
        && request.resource.data.status == 'active'
        && request.resource.data.keys().hasOnly([
          'driverId',
          'routeId',
          'originTerminalId',
          'destinationTerminalId',
          'status',
          'startedAt',
          'updatedAt'
        ]);

      allow update: if false;

      allow delete: if (isDriver() && isOwner(driverId) && resource.data.driverId == request.auth.uid)
        || isAdmin();
    }

    match /vehicleLocations/{driverId} {
      allow read: if signedIn();

      allow create, update: if ((isDriver() && isOwner(driverId)) || isAdmin())
        && request.resource.data.driverId == driverId
        && request.resource.data.tripId == driverId
        && activeTripMatchesRequest(driverId, request.resource.data.routeId)
        && request.resource.data.keys().hasOnly([
          'driverId',
          'tripId',
          'routeId',
          'latitude',
          'longitude',
          'heading',
          'speed',
          'accuracy',
          'recordedAt',
          'updatedAt'
        ]);

      allow delete: if ((isDriver() && isOwner(driverId) && resource.data.driverId == request.auth.uid)
        || isAdmin());
    }

    match /tripEvents/{eventId} {
      allow create: if isDriver()
        && request.resource.data.driverId == request.auth.uid
        && request.resource.data.tripId == request.auth.uid
        && request.resource.data.eventType in ['trip_started', 'trip_ended']
        && request.resource.data.keys().hasOnly([
          'tripId',
          'driverId',
          'routeId',
          'eventType',
          'recordedAt',
          'metadata'
        ]);

      allow read: if isAdmin()
        || (signedIn() && resource.data.driverId == request.auth.uid);

      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
