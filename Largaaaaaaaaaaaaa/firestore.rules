rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDocPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function activeTripPath(driverId) {
      return /databases/$(database)/documents/activeTrips/$(driverId);
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userHasApprovedRole(uid, role) {
      return signedIn()
        && exists(userDocPath(uid))
        && (
          (
            get(userDocPath(uid)).data.approvedRoles is list
            && get(userDocPath(uid)).data.approvedRoles.hasAny([role])
          )
          || (
            !(get(userDocPath(uid)).data.approvedRoles is list)
            && get(userDocPath(uid)).data.keys().hasAny(['role'])
            && get(userDocPath(uid)).data.role == role
          )
          || (
            get(userDocPath(uid)).data.approvedRoles is list
            && get(userDocPath(uid)).data.approvedRoles.size() == 0
            && get(userDocPath(uid)).data.keys().hasAny(['role'])
            && get(userDocPath(uid)).data.role == role
          )
        );
    }

    function isAdmin() {
      return userHasApprovedRole(request.auth.uid, 'admin');
    }

    function isDriver() {
      return userHasApprovedRole(request.auth.uid, 'driver');
    }

    function isCommuter() {
      return userHasApprovedRole(request.auth.uid, 'commuter');
    }

    function activeTripMatchesRequest(driverId, routeId) {
      return exists(activeTripPath(driverId))
        && get(activeTripPath(driverId)).data.driverId == driverId
        && get(activeTripPath(driverId)).data.routeId == routeId;
    }

    function validRouteProgressSegmentIndex(value) {
      return value == null || (value is int && value >= 0);
    }

    function validActiveTripShape(data, driverId) {
      return data.driverId == driverId
        && data.routeId is string
        && data.originTerminalId is string
        && data.destinationTerminalId is string
        && data.originTerminalId != data.destinationTerminalId
        && data.status == 'active'
        && data.startedAt is string
        && data.updatedAt is string
        && validRouteProgressSegmentIndex(data.routeProgressSegmentIndex);
    }

    function validCommuterPresenceShape(data, commuterId) {
      return data.commuterId == commuterId
        && data.status in ['waiting', 'active']
        && data.latitude is number
        && data.latitude >= -90
        && data.latitude <= 90
        && data.longitude is number
        && data.longitude >= -180
        && data.longitude <= 180
        && data.referenceSource in ['gps', 'manual']
        && data.nearbyRouteIds is list
        && data.nearbyRouteIds.size() <= 12
        && data.recordedAt is string
        && data.updatedAt is string;
    }

    function driverCanReadCommuterPresence() {
      return isDriver()
        && exists(activeTripPath(request.auth.uid))
        && resource.data.nearbyRouteIds is list
        && resource.data.nearbyRouteIds.hasAny([
          get(activeTripPath(request.auth.uid)).data.routeId
        ]);
    }

    function driverCanReadRouteCommuterPresence(routeId) {
      return isDriver()
        && exists(activeTripPath(request.auth.uid))
        && get(activeTripPath(request.auth.uid)).data.routeId == routeId;
    }

    function ownerCanUpdateActiveTripProgress(driverId) {
      return isDriver()
        && isOwner(driverId)
        && resource.data.driverId == request.auth.uid
        && request.resource.data.driverId == resource.data.driverId
        && request.resource.data.routeId == resource.data.routeId
        && request.resource.data.originTerminalId == resource.data.originTerminalId
        && request.resource.data.destinationTerminalId == resource.data.destinationTerminalId
        && request.resource.data.status == resource.data.status
        && request.resource.data.startedAt == resource.data.startedAt
        && request.resource.data.keys().hasOnly([
          'driverId',
          'routeId',
          'originTerminalId',
          'destinationTerminalId',
          'routeProgressSegmentIndex',
          'status',
          'startedAt',
          'updatedAt'
        ])
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'routeProgressSegmentIndex',
          'updatedAt'
        ])
        && validRouteProgressSegmentIndex(request.resource.data.routeProgressSegmentIndex);
    }

    function validPublicUserProfile() {
      return request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && (request.resource.data.phoneNumber == null || request.resource.data.phoneNumber is string)
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string
        && request.resource.data.primaryRole in ['commuter', 'driver']
        && request.resource.data.approvedRoles is list
        && request.resource.data.approvedRoles.size() <= 1
        && request.resource.data.approvedRoles.hasOnly(['commuter'])
        && request.resource.data.pendingRoleRequests is list
        && request.resource.data.pendingRoleRequests.size() <= 1
        && request.resource.data.pendingRoleRequests.hasOnly(['driver'])
        && !(request.resource.data.approvedRoles.size() == 0 && request.resource.data.pendingRoleRequests.size() == 0)
        && (
          (
            request.resource.data.approvedRoles.hasAny(['commuter'])
            && request.resource.data.primaryRole == 'commuter'
          )
          || (
            !request.resource.data.approvedRoles.hasAny(['commuter'])
            && request.resource.data.pendingRoleRequests.hasAny(['driver'])
            && request.resource.data.primaryRole == 'driver'
          )
        );
    }

    function validDriverApplicationPayload(data, uid) {
      return data.uid == uid
        && data.requestedRole == 'driver'
        && data.status == 'pending'
        && data.submittedAt is string
        && data.updatedAt is string
        && data.reviewNotes is list
        && data.reviewNotes.size() == 0
        && data.documents is map
        && data.documents.keys().hasOnly([
          'vehicleType',
          'plateNumber',
          'licenseNumber',
          'idImagePath',
          'idImageUrl'
        ])
        && data.documents.vehicleType is string
        && data.documents.plateNumber is string
        && data.documents.licenseNumber is string
        && (data.documents.idImagePath == null || data.documents.idImagePath is string)
        && (data.documents.idImageUrl == null || data.documents.idImageUrl is string);
    }

    function validDriverApplicationDocumentShape(data, uid) {
      return data.uid == uid
        && data.requestedRole == 'driver'
        && data.submittedAt is string
        && data.updatedAt is string
        && data.reviewNotes is list
        && data.documents is map
        && data.documents.keys().hasOnly([
          'vehicleType',
          'plateNumber',
          'licenseNumber',
          'idImagePath',
          'idImageUrl'
        ])
        && data.documents.vehicleType is string
        && data.documents.plateNumber is string
        && data.documents.licenseNumber is string
        && (data.documents.idImagePath == null || data.documents.idImagePath is string)
        && (data.documents.idImageUrl == null || data.documents.idImageUrl is string);
    }

    function ownerCanUpdateDriverApplication() {
      return signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.requestedRole == resource.data.requestedRole
        && request.resource.data.submittedAt == resource.data.submittedAt
        && request.resource.data.reviewNotes == resource.data.reviewNotes
        && request.resource.data.keys().hasOnly([
          'uid',
          'requestedRole',
          'status',
          'submittedAt',
          'updatedAt',
          'documents',
          'reviewNotes'
        ])
        && validDriverApplicationDocumentShape(request.resource.data, request.auth.uid)
        && (
          (
            resource.data.status == 'pending'
            && request.resource.data.status == 'pending'
          )
          || (
            resource.data.status == 'needs_resubmission'
            && request.resource.data.status == 'pending'
          )
        );
    }

    function adminCanUpdateDriverApplication() {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.requestedRole == resource.data.requestedRole
        && request.resource.data.submittedAt == resource.data.submittedAt
        && request.resource.data.status in ['pending', 'approved', 'rejected', 'needs_resubmission']
        && request.resource.data.keys().hasOnly([
          'uid',
          'requestedRole',
          'status',
          'submittedAt',
          'updatedAt',
          'documents',
          'reviewNotes'
        ])
        && validDriverApplicationDocumentShape(request.resource.data, resource.data.uid);
    }

    function ownerCanRequestPendingDriverRole() {
      return request.resource.data.approvedRoles == resource.data.approvedRoles
        && request.resource.data.primaryRole == resource.data.primaryRole
        && resource.data.approvedRoles is list
        && resource.data.approvedRoles.hasOnly(['commuter'])
        && resource.data.pendingRoleRequests is list
        && resource.data.pendingRoleRequests.size() == 0
        && request.resource.data.pendingRoleRequests is list
        && request.resource.data.pendingRoleRequests.size() == 1
        && request.resource.data.pendingRoleRequests.hasOnly(['driver']);
    }

    match /users/{uid} {
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'phoneNumber',
          'approvedRoles',
          'pendingRoleRequests',
          'primaryRole',
          'createdAt',
          'updatedAt'
        ])
        && validPublicUserProfile();

      allow read: if isOwner(uid) || isAdmin();

      allow update: if isAdmin()
        || (
          isOwner(uid)
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.createdAt == resource.data.createdAt
          && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'email',
              'displayName',
              'phoneNumber',
              'updatedAt'
            ])
            || (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'displayName',
                'phoneNumber',
                'updatedAt',
                'pendingRoleRequests'
              ])
              && ownerCanRequestPendingDriverRole()
            )
          )
        );

      allow delete: if isAdmin();
    }

    match /roleApplications/{applicationId} {
      allow create: if signedIn()
        && validDriverApplicationPayload(request.resource.data, request.auth.uid)
        && request.resource.data.keys().hasOnly([
          'uid',
          'requestedRole',
          'status',
          'submittedAt',
          'updatedAt',
          'documents',
          'reviewNotes'
        ]);

      allow read: if (signedIn() && resource.data.uid == request.auth.uid) || isAdmin();

      allow update: if isAdmin()
        && adminCanUpdateDriverApplication()
        || ownerCanUpdateDriverApplication();

      allow delete: if isAdmin();
    }

    match /routes/{routeId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /terminals/{terminalId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /activeTrips/{driverId} {
      allow read: if signedIn();

      allow create: if isDriver()
        && isOwner(driverId)
        && validActiveTripShape(request.resource.data, driverId)
        && request.resource.data.keys().hasOnly([
          'driverId',
          'routeId',
          'originTerminalId',
          'destinationTerminalId',
          'routeProgressSegmentIndex',
          'status',
          'startedAt',
          'updatedAt'
        ]);

      allow update: if ownerCanUpdateActiveTripProgress(driverId) || isAdmin();

      allow delete: if (isDriver() && isOwner(driverId) && resource.data.driverId == request.auth.uid)
        || isAdmin();
    }

    match /vehicleLocations/{driverId} {
      allow read: if signedIn();

      allow create, update: if ((isDriver() && isOwner(driverId)) || isAdmin())
        && request.resource.data.driverId == driverId
        && request.resource.data.tripId == driverId
        && activeTripMatchesRequest(driverId, request.resource.data.routeId)
        && request.resource.data.keys().hasOnly([
          'driverId',
          'tripId',
          'routeId',
          'latitude',
          'longitude',
          'heading',
          'speed',
          'accuracy',
          'recordedAt',
          'updatedAt'
        ]);

      allow delete: if ((isDriver() && isOwner(driverId) && resource.data.driverId == request.auth.uid)
        || isAdmin());
    }

    match /commuterPresence/{commuterId} {
      allow get: if isOwner(commuterId) || isAdmin() || driverCanReadCommuterPresence();
      allow list: if isAdmin();

      allow create, update: if isCommuter()
        && isOwner(commuterId)
        && validCommuterPresenceShape(request.resource.data, commuterId)
        && request.resource.data.keys().hasOnly([
          'commuterId',
          'status',
          'latitude',
          'longitude',
          'referenceSource',
          'nearbyRouteIds',
          'recordedAt',
          'updatedAt'
        ]);

      allow delete: if (isCommuter() && isOwner(commuterId)) || isAdmin();
    }

    match /routeCommuterPresence/{routeId}/commuters/{commuterId} {
      allow read: if isAdmin() || driverCanReadRouteCommuterPresence(routeId);

      allow create, update: if isCommuter()
        && isOwner(commuterId)
        && validCommuterPresenceShape(request.resource.data, commuterId)
        && request.resource.data.nearbyRouteIds.hasAny([routeId])
        && request.resource.data.keys().hasOnly([
          'commuterId',
          'status',
          'latitude',
          'longitude',
          'referenceSource',
          'nearbyRouteIds',
          'recordedAt',
          'updatedAt'
        ]);

      allow delete: if (isCommuter() && isOwner(commuterId)) || isAdmin();
    }

    match /tripEvents/{eventId} {
      allow create: if isDriver()
        && request.resource.data.driverId == request.auth.uid
        && request.resource.data.tripId == request.auth.uid
        && request.resource.data.eventType in ['trip_started', 'trip_ended']
        && request.resource.data.keys().hasOnly([
          'tripId',
          'driverId',
          'routeId',
          'eventType',
          'recordedAt',
          'metadata'
        ]);

      allow read: if isAdmin()
        || (signedIn() && resource.data.driverId == request.auth.uid);

      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
